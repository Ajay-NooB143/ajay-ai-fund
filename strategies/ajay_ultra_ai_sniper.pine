//@version=5
strategy("AJAY ULTRA AI SNIPER 💀 FINAL", overlay=true, default_qty_type=strategy.percent_of_equity, default_qty_value=10)

// ================= INPUTS =================
emaLen = input.int(50)
atrLen = input.int(14)
rr     = input.float(2.0)

// ================= CORE =================
ema = ta.ema(close, emaLen)
atr = ta.atr(atrLen)

plot(ema, color=color.orange)

// ================= HTF =================
htf = request.security(syminfo.tickerid, "60", ta.ema(close, 50))
bullHTF = close > htf
bearHTF = close < htf

// ================= REGIME =================
adx = ta.adx(14)

trendUp   = close > ema and adx > 25
trendDown = close < ema and adx > 25
range     = adx < 20

// ================= KILLZONE =================
hourUTC = hour(time, "UTC")
killzone = (hourUTC >= 7 and hourUTC <= 10) or (hourUTC >= 13 and hourUTC <= 16)

// ================= ICT =================
// MSS
mssBuy  = ta.crossover(close, ta.highest(high, 5)[1])
mssSell = ta.crossunder(close, ta.lowest(low, 5)[1])

// FVG
fvgBuy  = low > high[2]
fvgSell = high < low[2]

// Liquidity
sHigh = ta.highest(high, 20)
sLow  = ta.lowest(low, 20)

liqBuy  = low < sLow[1]
liqSell = high > sHigh[1]

// ================= AI SCORE =================
scoreBuy = 0
scoreBuy += bullHTF ? 1 : 0
scoreBuy += trendUp ? 1 : 0
scoreBuy += mssBuy ? 1 : 0
scoreBuy += fvgBuy ? 1 : 0
scoreBuy += liqBuy ? 1 : 0

scoreSell = 0
scoreSell += bearHTF ? 1 : 0
scoreSell += trendDown ? 1 : 0
scoreSell += mssSell ? 1 : 0
scoreSell += fvgSell ? 1 : 0
scoreSell += liqSell ? 1 : 0

// ================= ENTRY =================
buy  = scoreBuy >= 4 and killzone
sell = scoreSell >= 4 and killzone

// ================= SMART TP =================
liqTPBuy  = ta.highest(high, 30)
liqTPSell = ta.lowest(low, 30)

// ================= SL =================
longSL  = close - atr * 1.5
shortSL = close + atr * 1.5

// ================= ENTRY =================
if buy
    strategy.entry("BUY", strategy.long)

if sell
    strategy.entry("SELL", strategy.short)

// ================= PARTIAL TP =================
strategy.exit("TP1 BUY",  from_entry="BUY",  limit=liqTPBuy,  qty_percent=50)
strategy.exit("TP2 BUY",  from_entry="BUY",  limit=liqTPBuy + atr * rr)

strategy.exit("TP1 SELL", from_entry="SELL", limit=liqTPSell, qty_percent=50)
strategy.exit("TP2 SELL", from_entry="SELL", limit=liqTPSell - atr * rr)

// ================= TRAILING =================
strategy.exit("TS BUY",  from_entry="BUY",  trail_points=atr)
strategy.exit("TS SELL", from_entry="SELL", trail_points=atr)

// ================= VISUAL =================
plotshape(buy,  location=location.belowbar, color=color.lime, style=shape.triangleup, text="BUY")
plotshape(sell, location=location.abovebar, color=color.red,  style=shape.triangledown, text="SELL")

// ================= WINRATE =================
wins   = strategy.wintrades
losses = strategy.losstrades
total  = wins + losses
winrate = total > 0 ? (wins / total) * 100 : 0

// ================= DASHBOARD =================
var table dash = table.new(position.top_right, 2, 5)

if barstate.islast
    table.cell(dash, 0, 0, "WINRATE")
    table.cell(dash, 1, 0, str.tostring(winrate, "#.##") + "%")

    table.cell(dash, 0, 1, "TRADES")
    table.cell(dash, 1, 1, str.tostring(total))

    table.cell(dash, 0, 2, "SCORE")
    table.cell(dash, 1, 2, str.tostring(math.max(scoreBuy, scoreSell)))

    table.cell(dash, 0, 3, "REGIME")
    table.cell(dash, 1, 3, trendUp ? "TREND" : range ? "RANGE" : "WEAK")

    table.cell(dash, 0, 4, "SESSION")
    table.cell(dash, 1, 4, killzone ? "ACTIVE" : "OFF")

// ================= ALERT =================
alertcondition(buy,  "BUY",  "BUY SIGNAL")
alertcondition(sell, "SELL", "SELL SIGNAL")
